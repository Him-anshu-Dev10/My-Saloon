# Copy this to .env and fill the values
PORT=3000
NODE_ENV=development

# Either provide SUPABASE_ANON_KEY to use the Supabase JS client
# or provide SUPABASE_DB_URL (Postgres connection string) for direct PG access.
# SUPABASE_URL is still used by some parts of the app (e.g., auth URLs).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=


# SMTP config for OTP email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM=your@email.com

# Session secret for express-session
SESSION_SECRET=your-session-secret
